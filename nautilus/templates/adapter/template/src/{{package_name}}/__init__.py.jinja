"""{{ class_name }} — Nautilus adapter for the '{{ source_type }}' source type.

Generated by ``nautilus adapters new {{ adapter_name }}``. Replace the
in-memory sample rows with your real data source: open connections in
:meth:`connect`, query + apply scope constraints in :meth:`execute`, and
release resources in :meth:`close`.

See ``examples/custom-adapter/`` in the nautilus repo for a worked CSV
adapter, and ``docs/reference/adapter-sdk.md`` for the protocol contract.
"""

from __future__ import annotations

import time
from typing import Any, ClassVar

from nautilus_adapter_sdk.config import SourceConfig
from nautilus_adapter_sdk.exceptions import AdapterError, ScopeEnforcementError
from nautilus_adapter_sdk.types import AdapterResult, IntentAnalysis, ScopeConstraint

# Operators this adapter knows how to enforce. Anything else must raise
# ScopeEnforcementError (fail closed) — the SDK compliance suite checks this.
_VALID_OPERATORS = {"=", "eq", "!=", "IN", "NOT IN", "LIKE", "IS NULL"}

# Placeholder data so the generated package works out of the box. Delete
# once connect()/execute() talk to your real source.
_SAMPLE_ROWS: list[dict[str, str]] = [
    {"id": "1", "name": "alpha"},
    {"id": "2", "name": "beta"},
]


class {{ class_name }}:
    """Adapter for the '{{ source_type }}' source type."""

    source_type: ClassVar[str] = "{{ source_type }}"

    def __init__(self) -> None:
        self._config: SourceConfig | None = None
        self._rows: list[dict[str, str]] = []
        self._closed = False

    async def connect(self, config: SourceConfig) -> None:
        """Initialise adapter state for ``config``.

        ``config.connection`` carries the DSN / base URL / file path from
        the source block in nautilus.yaml.
        """
        self._config = config
        self._rows = list(_SAMPLE_ROWS)

    async def execute(
        self,
        intent: IntentAnalysis,
        scope: list[ScopeConstraint],
        context: dict[str, Any],
    ) -> AdapterResult:
        """Run a scoped query and return matching rows."""
        if self._config is None:
            raise AdapterError("{{ class_name }}.execute() called before connect()")

        started = time.perf_counter()
        rows = list(self._rows)

        for constraint in scope:
            op = constraint.operator
            if op not in _VALID_OPERATORS:
                raise ScopeEnforcementError(
                    f"{{ class_name }}: unsupported operator '{op}'"
                )
            field = constraint.field
            value = constraint.value
            if op in ("=", "eq"):
                rows = [r for r in rows if r.get(field) == str(value)]
            elif op == "!=":
                rows = [r for r in rows if r.get(field) != str(value)]
            elif op == "IN":
                values = [str(v) for v in value] if isinstance(value, list) else [str(value)]
                rows = [r for r in rows if r.get(field) in values]
            elif op == "NOT IN":
                values = [str(v) for v in value] if isinstance(value, list) else [str(value)]
                rows = [r for r in rows if r.get(field) not in values]
            elif op == "LIKE":
                pattern = str(value).replace("%", "").lower()
                rows = [r for r in rows if pattern in r.get(field, "").lower()]
            elif op == "IS NULL":
                rows = [r for r in rows if not r.get(field)]

        duration_ms = int((time.perf_counter() - started) * 1000)
        return AdapterResult(
            source_id=scope[0].source_id if scope else "{{ source_type }}",
            data=rows,
            metadata={
                "row_count": len(rows),
                "duration_ms": duration_ms,
            },
        )

    async def close(self) -> None:
        """Release resources. Idempotent — second call is a no-op."""
        if self._closed:
            return
        self._closed = True
        self._rows = []


__all__ = ["{{ class_name }}"]
